# Skopiuj jako backend/.env i uzupełnij wartości
DATABASE_URL=postgresql://postgres:TWOJE_HASLO@localhost:5432/kebab_mes

# Lista dozwolonych originów CORS (po przecinku). NIE używaj "*" w produkcji.
# Przykład: http://204.168.166.34:8080,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Token wymagany w nagłówku X-Admin-Token na endpointach /api/admin/*
ADMIN_TOKEN=

# Klucz API dataport.pl (lookup GUS po NIP)
DATAPORT_API_KEY=

# (opcjonalnie) VIES — walidacja VAT UE
VIES_API_ID=
VIES_API_KEY=
