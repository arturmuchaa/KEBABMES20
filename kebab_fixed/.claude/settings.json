{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm test:*)",
      "Bash(npm ci)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx vitest run:*)",
      "Bash(npx playwright test:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(diff -rq:*)",
      "Bash(curl -sf 127.0.0.1:8010/api/health)"
    ]
  }
}
