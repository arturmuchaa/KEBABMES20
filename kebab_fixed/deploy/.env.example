# WZÓR konfiguracji klienta. Nie używaj wprost — uruchom: bash deploy/nowy-klient.sh <slug>
# który wygeneruje clients/<slug>/.env z losowymi sekretami.

COMPOSE_PROJECT_NAME=kebab-przyklad
CLIENT_NAME="Przykładowy Zakład sp. z o.o."
CLIENT_NIP=0000000000

# Port na hoście, pod którym dostępne UI + API klienta
APP_PORT=8080

# Postgres (serwis 'db' w compose)
POSTGRES_DB=kebab_mes
POSTGRES_USER=kebab
POSTGRES_PASSWORD=ZMIEN_MNIE
# Pełny URL z hasłem wstawionym na sztywno; host 'db' = kontener Postgresa
DATABASE_URL=postgresql://kebab:ZMIEN_MNIE@db:5432/kebab_mes

# Moduły włączone u tego klienta. Pusto = wszystkie.
# Np. tylko rozbiór:  MODULES=rozbior
#     kebab pełny:    MODULES=rozbior,produkcja,wz,etykiety
MODULES=

# Integracje / bezpieczeństwo
CORS_ORIGINS=*
DATAPORT_API_KEY=
ADMIN_TOKEN=
