{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rozbior HMI",
  "version": "1.0.41",
  "identifier": "pl.kebabmes.rozbior-v10",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rozbiór HMI",
        "url": "rozbior-v10.html",
        "fullscreen": true,
        "decorations": false,
        "resizable": false,
        "maximized": true,
        "skipTaskbar": false,
        "focus": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8000 http://localhost:8080 http://204.168.166.34 http://204.168.166.34:8000 http://204.168.166.34:8080"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4NkZBOTM4RkYyRjdERUUKUldUdWZTLy9PS2x2U0Z2VnNZRkhMOEtIcXUyUkF0eUJkNTJmMEpzWGlkN090eGxkWG1yUjZJdWMK",
      "endpoints": [
        "http://204.168.166.34:8080/api/desktop-updates/rozbior-v10/latest.json"
      ],
      "dangerousInsecureTransportProtocol": true,
      "dialog": false,
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Polish"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
