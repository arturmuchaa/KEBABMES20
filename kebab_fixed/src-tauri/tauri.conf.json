{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kebab MES",
  "version": "2.3.0",
  "identifier": "pl.kebabmes.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kebab MES",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Polish"],
        "displayLanguageSelector": false
      }
    }
  }
}
