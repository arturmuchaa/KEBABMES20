{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kebab MES",
  "version": "2.5.11",
  "identifier": "pl.kebabmes.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kebab MES",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8000 http://204.168.166.34 http://204.168.166.34:8000 http://204.168.166.34:8080 https://raw.githubusercontent.com https://github.com https://objects.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4NkZBOTM4RkYyRjdERUUKUldUdWZTLy9PS2x2U0Z2VnNZRkhMOEtIcXUyUkF0eUJkNTJmMEpzWGlkN090eGxkWG1yUjZJdWMK",
      "endpoints": [
        "https://raw.githubusercontent.com/arturmuchaa/kebabmes20/main/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Polish"],
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    }
  }
}
