{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kebab MES",
  "version": "2.3.0",
  "identifier": "pl.kebabmes.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kebab MES",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Kebab MES",
    "copyright": "© 2025 Kebab MES",
    "category": "BusinessApp",
    "shortDescription": "System zarządzania produkcją kebaba",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "languages": ["Polish"],
        "displayLanguageSelector": false,
        "installMode": "perMachine",
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "Kebab MES"
      }
    }
  }
}
