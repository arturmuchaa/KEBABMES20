{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rozbiór HMI",
  "version": "1.0.2",
  "identifier": "pl.kebabmes.rozbior-v7",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rozbiór HMI",
        "url": "rozbior-v7.html",
        "fullscreen": true,
        "decorations": false,
        "resizable": false,
        "maximized": true,
        "skipTaskbar": false,
        "focus": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8000 http://localhost:8080 http://204.168.166.34 http://204.168.166.34:8000 http://204.168.166.34:8080"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Polish"],
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    }
  }
}
